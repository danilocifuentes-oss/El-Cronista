# Copia este archivo a `.env.local` y rellena la clave (no subas `.env.local` a Git).

# Google AI Studio: https://aistudio.google.com/apikey
# En la web de Google el nombre puede decir «Gemini API Key»; eso NO es el nombre de la variable.
# En Vercel / aquí la variable debe llamarse exactamente:
GEMINI_API_KEY=
# Opcional (mismo valor si ya lo tienes con otro nombre de tutorial):
# GOOGLE_GENERATIVE_AI_API_KEY=

# Opcional. Por defecto: gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash

# Si el modelo principal agota cuota (429), la API reintenta con este modelo.
# GEMINI_MODEL_FALLBACK=gemini-1.5-flash

# Acceso «operador» en cliente (login numérico): variable documentada en código (ROOT_OPERATOR_CIPHER).
# No sustituye API keys ni auth servidor.
